# Backend selection: "ollama" or "lmstudio"
BACKEND=ollama

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest

# LM Studio settings
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=

# Analysis settings
ANALYSIS_TEMPERATURE=0.0
SUGGESTION_TEMPERATURE=0.3
MAX_ANALYSIS_TOKENS=256
MAX_SUGGESTION_TOKENS=512
OLLAMA_TIMEOUT=30.0

# Server
HOST=127.0.0.1
PORT=8765
DB_PATH=agent_enum.db

# Bisect settings
BISECT_MAX_ITERATIONS=8
BISECT_MIN_WORDS=3
